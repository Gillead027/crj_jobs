# Esta lista evita que arquivos gerados pelo Node.js sejam salvos no Git.
node_modules

# Esta lista evita salvar a pasta de build criada pelo Next.js.
.next

# Esta lista evita salvar arquivos de ambiente com dados sensiveis.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Esta lista evita salvar logs criados por comandos do npm.
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Esta lista evita salvar logs locais do servidor de desenvolvimento.
next-dev.log
next-dev.err.log

# Esta lista evita salvar cache incremental criado pelo TypeScript.
tsconfig.tsbuildinfo

# Esta lista evita salvar arquivos temporarios do sistema operacional.
.DS_Store
Thumbs.db
